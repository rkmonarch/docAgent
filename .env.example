# ── DocAgent LLM Provider Config ─────────────────────────────────────────────
# Pick ONE provider. Fill in its key. All use open-source models.

# ① Groq — RECOMMENDED · free · DeepSeek R1 + Llama 3.3 · console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ② DeepSeek — $5 free credit · best coding/reasoning · platform.deepseek.com
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ③ Mistral — free tier · EU-based · open weights · console.mistral.ai
# MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ④ Cerebras — free tier · fastest inference · cloud.cerebras.ai
# CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ⑤ OpenRouter — free :free models (DeepSeek R1, Llama, Mistral) · openrouter.ai
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ⑥ Together AI — $1 free credit · DeepSeek R1 + Llama 3.3 · api.together.ai
# TOGETHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ⑦ Ollama — local, zero API key · ollama.com
#    ollama pull deepseek-r1:7b   (recommended local model)
#    ollama pull llama3.2
# OLLAMA_HOST=http://localhost:11434
# DOCAGENT_OLLAMA_MODEL=deepseek-r1:7b

# ── Active provider ───────────────────────────────────────────────────────────
DOCAGENT_PROVIDER=groq
